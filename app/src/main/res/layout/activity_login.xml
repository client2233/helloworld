<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@android:color/white">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="欢迎回来"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#5F587E"
        android:layout_marginBottom="8dp" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="要继续，请验证您的身份"
        android:textSize="14sp"
        android:textColor="@color/auth_hint_lavender"
        android:layout_marginBottom="48dp" />
    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="请输入您的账号"
        android:textColor="#000000"
        android:textColorHint="#000000"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_user"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:inputType="text"
        android:background="@drawable/bg_login_input_white_stroke"
        android:backgroundTint="@null"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="请输入您的密码"
        android:textColor="#000000"
        android:textColorHint="#000000"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_password"
        android:drawableEnd="@drawable/ic_visibility_off"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:inputType="textPassword"
        android:background="@drawable/bg_login_input_white_stroke"
        android:backgroundTint="@null"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbRememberMe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_remember_me"
            android:textColor="#5F587E" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_forgot_password"
            android:textColor="#5F587E"
            android:textSize="14sp"
            android:padding="8dp" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="登录"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_login_button_gradient" />

    <TextView
        android:id="@+id/tvOtherLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/auth_other_login"
        android:textColor="#888888"
        android:textSize="13sp" />

    <View
        android:id="@+id/viewOtherLoginDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp"
        android:background="#E0E0E0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/tvPhoneLogin"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/auth_phone_login"
            android:textColor="#5F587E"
            android:textSize="14sp"
            android:gravity="center"
            android:textAlignment="center"
            android:drawableStart="@drawable/ic_login_phone"
            android:drawablePadding="6dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:background="@drawable/bg_login_input_white_stroke"
            android:backgroundTint="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/tvWechatLogin"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/auth_wechat_login"
            android:textColor="#5F587E"
            android:textSize="14sp"
            android:gravity="center"
            android:textAlignment="center"
            android:drawableStart="@drawable/ic_login_wechat"
            android:drawablePadding="6dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:background="@drawable/bg_login_input_white_stroke"
            android:backgroundTint="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvToRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="没有账号？去注册"
        android:textColor="#5F587E"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:padding="8dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

</LinearLayout>